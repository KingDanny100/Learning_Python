from turtle import Turtle, Screen
import random


screen = Screen()
colours = ['red','yellow','green','blue','purple',"orange"]
y_positions = [-60,-30,0, 30, 60,90]
isRaceOn = False

all_turtles = []

screen.setup(width=500,height=400)
user_bet = screen.textinput(title="Make your bet:", prompt="Which turtle will win the race? Pick a colour: ")
if user_bet:
    isRaceOn = True

for turtle_index in range(0,6):
    new_turtle = Turtle(shape="turtle")
    new_turtle.color(colours[turtle_index])
    new_turtle.penup()
    new_turtle.goto(x=-230,y=y_positions[turtle_index])
    all_turtles.append(new_turtle)

while isRaceOn:
    for turtle in all_turtles:
       if turtle.xcor() >= 230:
           isRaceOn= False
           winning_colour = turtle.pencolor()
           if user_bet==winning_colour:
               print(f'You won!! the {winning_colour} turtle won')
           else:
                print(f'You lost!! the {winning_colour} turtle won')

       rand_num = random.randint(0,10)
       turtle.forward(rand_num)
       



screen.exitonclick()
